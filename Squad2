  pill.innerHTML = `<span class="risk-pill ${p.class}">${p.label}</span>`;

  document.getElementById('modal-status').textContent = c.status;

  const list = document.getElementById('modal-todos');
  list.innerHTML = c.todos.map(t =>
    `<li><span class="todo-dot ${dotClasses[c.risco]}"></span>${t}</li>`
  ).join('');
  const resps = document.getElementById('modal-resps');
  if (c.resps.length) {
    resps.innerHTML = c.resps.map(r => `<span class="resp-badge">${r}</span>`).join('');
  } else {
    resps.innerHTML = '<span style="color:var(--muted);font-size:13px">Não definido</span>';
  }
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
}

function closeModalOnOverlay(e) {
  if (e.target === document.getElementById('modal-overlay')) closeModal();
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

function filterCards(type, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => {
    b.className = 'filter-btn';
  });
  if (type === 'todos') btn.className = 'filter-btn active-all';
  else btn.className = `filter-btn active-${type}`;

  const cards = document.querySelectorAll('.client-card');
  cards.forEach(card => {
    if (type === 'todos' || card.dataset.risco === type) {
      card.classList.remove('hidden');
    } else {
      card.classList.add('hidden');
    }
  });

  // Hide/show section groups
  const groups = {
    alto: document.getElementById('group-alto'),
    medio: document.getElementById('group-medio'),
    baixo: document.getElementById('group-baixo'),
    setup: document.getElementById('group-setup')
  };

  if (type === 'todos') {
    Object.values(groups).forEach(g => g.classList.remove('hidden'));
  } else {
    Object.entries(groups).forEach(([key, g]) => {
      if (key === type) g.classList.remove('hidden');
      else g.classList.add('hidden');
    });
  }
}
